---
import '../styles/base.css';
import '../styles/components.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  lang: 'fr' | 'en';
  canonical?: string;
}

const { title, description, lang, canonical } = Astro.props;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://ludovic.bostral.com/#person",
  name: "Ludovic Bostral",
  url: "https://ludovic.bostral.com/",
  jobTitle: "Founder & Analyst",
  description: "Founder and analyst — Streaming Lens, verticaldrama.tv and Streaming Radar. Vertical drama, micro-drama and streaming intelligence.",
  knowsAbout: ["Vertical drama", "Micro-drama", "Streaming", "OTT Africa", "Generative AI video", "Media analysis"],
  sameAs: [
    "https://x.com/ludobos",
    "https://www.linkedin.com/in/ludovicbostral/",
    "https://www.crunchbase.com/person/ludovic-bostral",
    "https://lens.streaming-radar.com/about",
    "https://verticaldrama.tv/about/",
    "https://www.streaming-radar.com"
  ]
};
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>

  <link rel="preload" href="/fonts/SpaceGrotesk-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/SpaceGrotesk-SemiBold.woff2" as="font" type="font/woff2" crossorigin>

  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Ludovic Bostral">
  <meta property="og:image" content={new URL('/assets/og-image.svg', Astro.site).href}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>

  <link rel="icon" href="/favicon.ico">

  {lang === 'fr' ? (
    <link rel="alternate" hreflang="en" href={new URL('/en/' , Astro.site).href}>
    <link rel="alternate" hreflang="fr" href={canonicalUrl}>
  ) : (
    <link rel="alternate" hreflang="fr" href={new URL('/', Astro.site).href}>
    <link rel="alternate" hreflang="en" href={canonicalUrl}>
  )}

  <meta name="twitter:creator" content="@ludobos">

  <link rel="me" href="https://x.com/ludobos">
  <link rel="me" href="https://www.linkedin.com/in/ludovicbostral/">
  <link rel="me" href="https://www.crunchbase.com/person/ludovic-bostral">
  <link rel="me" href="https://lens.streaming-radar.com/about">
  <link rel="me" href="https://verticaldrama.tv/about/">
  <link rel="me" href="https://www.streaming-radar.com">

  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
</head>
<body>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <CookieConsent lang={lang} />
</body>
</html>
