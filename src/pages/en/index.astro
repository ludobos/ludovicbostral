---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Profile from '../../components/Profile.astro';
import Contact from '../../components/Contact.astro';
import { getHomeContent } from '../../utils/i18n';

const lang = 'en';
const c = getHomeContent(lang);
---
<Base title={c.meta.title} description={c.meta.description} lang={lang}>
  <Hero name={c.hero.name} tagline={c.hero.tagline} context={c.hero.context} ctaPrimary={c.hero.ctaPrimary} ctaSecondary={c.hero.ctaSecondary} location={c.hero.location} />
  <Profile title={c.profile.title} intro={c.profile.intro} lensLink={c.profile.lensLink} careerTitle={c.profile.careerTitle} career={c.profile.career} also={c.profile.also} alsoLinks={c.profile.alsoLinks} />
  <Contact title={c.contact.title} ctaText={c.contact.ctaText} ctaUrl={c.contact.ctaUrl} email={c.contact.email} linkedinText={c.contact.linkedinText} linkedinUrl={c.contact.linkedinUrl} location={c.contact.location} />
</Base>
