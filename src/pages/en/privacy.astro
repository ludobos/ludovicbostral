---
import Base from '../../layouts/Base.astro';
---
<Base title="Privacy - Ludovic Bostral" description="Privacy policy for bostral.com" lang="en" alternateUrl="/privacy/">
  <section>
    <div class="container container--narrow">
      <h1>Privacy policy</h1>
      <h2>Analytics</h2>
      <p>This site uses Google Analytics (GA4) to measure audience. Data is collected anonymously and not shared with third parties. You can decline tracking via the consent banner shown on your first visit.</p>
      <h2>Cookies</h2>
      <p>Only a consent preference is stored locally. No advertising or third-party tracking cookies are present on this site.</p>
      <h2>Personal data</h2>
      <p>No personal data is collected beyond what Google Analytics provides anonymously. Call bookings go through Cal.com, which has its own privacy policy.</p>
      <h2>Contact</h2>
      <p>For any data protection questions: <a href="mailto:ludovic@streaming-radar.com">ludovic@streaming-radar.com</a></p>
    </div>
  </section>
</Base>
