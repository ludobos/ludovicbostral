---
interface Props {
  title: string;
  intro: string;
  lensLink: { text: string; url: string };
  careerTitle: string;
  career: Array<{ period: string; company: string; role: string; detail: string }>;
  also: string;
  alsoLinks: Array<{ text: string; url: string }>;
}
const { title, intro, lensLink, careerTitle, career, also, alsoLinks } = Astro.props;
---
<section id="profile" class="profile">
  <div class="container container--narrow">
    <h2>{title}</h2>
    <p class="profile__intro">{intro}</p>
    <a href={lensLink.url} class="profile__lens-link">{lensLink.text} &rarr;</a>

    <h3 class="profile__career-title">{careerTitle}</h3>
    <div class="profile__career">
      {career.map(entry => (
        <div class="profile__career-entry">
          <span class="profile__career-period mono">{entry.period}</span>
          <span class="profile__career-company">{entry.company}</span>
          <span class="profile__career-role">{entry.role}</span>
          <span class="profile__career-detail">{entry.detail}</span>
        </div>
      ))}
    </div>

    <p class="profile__also">
      {also}
      {alsoLinks.map((link, i) => (
        <>{i > 0 && ' · '}<a href={link.url}>{link.text}</a></>
      ))}
    </p>
  </div>
</section>
