---
interface Props {
  name: string;
  tagline: string;
  context: string;
  ctaPrimary: { text: string; url: string };
  ctaSecondary: { text: string; url: string };
  location: string;
}
const { name, tagline, context, ctaPrimary, ctaSecondary, location } = Astro.props;
---
<section class="hero">
  <div class="container">
    <p class="hero__micro mono">{location}</p>
    <h1 class="hero__name">{name}</h1>
    <p class="hero__tagline">{tagline}</p>
    <p class="hero__context">{context}</p>
    <div class="hero__ctas">
      <a href={ctaPrimary.url} class="hero__cta-primary">{ctaPrimary.text}</a>
      <a href={ctaSecondary.url} class="hero__cta-secondary">{ctaSecondary.text}</a>
    </div>
  </div>
</section>
